{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "~/.ai_factory_one/bin/guard bash" }]
      },
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [{ "type": "command", "command": "~/.ai_factory_one/bin/guard write" }]
      }
    ]
  }
}
